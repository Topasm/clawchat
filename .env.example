# ===========================================
# ClawChat Environment Configuration
# ===========================================
# Copy this file to .env and update the values
#   cp .env.example .env

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- Database ---
DATABASE_URL=sqlite:///./data/clawchat.db

# --- Authentication ---
# JWT_SECRET is auto-generated each session if left as the default.
# Set a stable value for production so sessions survive restarts.
JWT_SECRET=change-this-to-a-random-secret-key

# Six-digit PIN used to log in
PIN=123456

# JWT token expiration in hours
JWT_EXPIRY_HOURS=24

# --- AI Provider ---
# Options: "ollama" or "openai" (also works with any OpenAI-compatible API)
AI_PROVIDER=ollama

# Ollama local:             http://localhost:11434
# Ollama via Docker Compose: http://ollama:11434
# OpenAI:                   https://api.openai.com
AI_BASE_URL=http://localhost:11434

# Required for OpenAI / Claude API; leave empty for Ollama
AI_API_KEY=

# Model name (e.g. llama3.2, gpt-4o, claude-3-opus, etc.)
AI_MODEL=llama3.2

# --- File Uploads ---
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=10

# --- Public URL ---
# If ClawChat is behind a reverse proxy (Cloudflare Tunnel, Caddy, Nginx, etc.),
# set this to the public-facing URL so pairing QR codes and API responses use
# the correct address instead of the local host/port.
# PUBLIC_URL=https://clawchat.example.com

# --- Frontend Default Server URL ---
# Baked into the frontend at build time. When set, the login page and Capacitor
# app use this as the default server URL instead of window.location.origin.
# Useful for Cloudflare Tunnel or any fixed reverse proxy hostname.
# VITE_DEFAULT_SERVER_URL=https://clawchat.example.com

# --- Obsidian ---
# Absolute path to your Obsidian vault (for one-way task export)
OBSIDIAN_VAULT_PATH=

# --- Scheduler ---
ENABLE_SCHEDULER=true
BRIEFING_TIME=08:00
REMINDER_CHECK_INTERVAL=60
