<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header: "Tasks" + count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/widget_header_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tasks"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_header_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9CA3AF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a4a" />

    <!-- Task list -->
    <LinearLayout
        android:id="@+id/widget_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- Task row 1 -->
        <LinearLayout
            android:id="@+id/task_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/task_check_1"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/widget_checkbox"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/task_title_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Task row 2 -->
        <LinearLayout
            android:id="@+id/task_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/task_check_2"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/widget_checkbox"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/task_title_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Task row 3 -->
        <LinearLayout
            android:id="@+id/task_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/task_check_3"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/widget_checkbox"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/task_title_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Task row 4 -->
        <LinearLayout
            android:id="@+id/task_row_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/task_check_4"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/widget_checkbox"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/task_title_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Task row 5 -->
        <LinearLayout
            android:id="@+id/task_row_5"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/task_check_5"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/widget_checkbox"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/task_title_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Extra tasks count -->
        <TextView
            android:id="@+id/task_extra"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#6B7280"
            android:textSize="12sp"
            android:paddingStart="28dp"
            android:paddingTop="2dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Empty state: setup prompt -->
    <TextView
        android:id="@+id/widget_empty_setup"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Open ClawChat to get started"
        android:textColor="#9CA3AF"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Empty state: tap to refresh -->
    <TextView
        android:id="@+id/widget_empty_refresh"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Tap to refresh"
        android:textColor="#818CF8"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Empty state: loading -->
    <TextView
        android:id="@+id/widget_loading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Refreshing..."
        android:textColor="#9CA3AF"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a4a" />

    <!-- Footer: Add Task -->
    <LinearLayout
        android:id="@+id/widget_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:gravity="center">

        <TextView
            android:id="@+id/btn_add_task"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:text="\uFF0B Add a task"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
