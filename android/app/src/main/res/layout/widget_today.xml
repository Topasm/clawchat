<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header: greeting + date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/widget_greeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Good morning"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mar 16"
            android:textColor="#9CA3AF"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a4a" />

    <!-- Content: tasks (left) + events (right) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <!-- Tasks column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical">

            <!-- Task row 1 -->
            <LinearLayout
                android:id="@+id/task_row_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/task_dot_1"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:src="@drawable/priority_dot"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/task_title_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E5E7EB"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Task row 2 -->
            <LinearLayout
                android:id="@+id/task_row_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/task_dot_2"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:src="@drawable/priority_dot"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/task_title_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E5E7EB"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Task row 3 -->
            <LinearLayout
                android:id="@+id/task_row_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/task_dot_3"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:src="@drawable/priority_dot"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/task_title_3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E5E7EB"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Extra tasks count -->
            <TextView
                android:id="@+id/task_extra"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#6B7280"
                android:textSize="12sp"
                android:paddingStart="14dp"
                android:paddingTop="1dp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Events column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <!-- Event row 1 -->
            <LinearLayout
                android:id="@+id/event_row_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/event_time_1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#818CF8"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/event_title_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E5E7EB"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>

            <!-- Event row 2 -->
            <LinearLayout
                android:id="@+id/event_row_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/event_time_2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#818CF8"
                    android:textSize="12sp"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/event_title_2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#E5E7EB"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a4a" />

    <!-- Action bar: Chat + Add Task -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:gravity="center">

        <TextView
            android:id="@+id/btn_chat"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:text="\uD83D\uDCAC Chat"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/btn_add_task"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:text="\uFF0B Task"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
