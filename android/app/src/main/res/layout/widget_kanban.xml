<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header: "Tasks" label -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/kanban_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tasks"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/kanban_total"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9CA3AF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a4a" />

    <!-- Status columns row -->
    <LinearLayout
        android:id="@+id/kanban_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="10dp"
        android:paddingBottom="6dp">

        <!-- To Do column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/kanban_todo_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#F59E0B"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="To Do"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- In Progress column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/kanban_progress_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#818CF8"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="In Progress"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Done column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/kanban_done_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#22C55E"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Done"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a4a" />

    <!-- Top priority tasks -->
    <LinearLayout
        android:id="@+id/kanban_tasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="6dp">

        <LinearLayout
            android:id="@+id/priority_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/priority_dot_1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/widget_dot"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/priority_title_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/priority_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/priority_dot_2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/widget_dot"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/priority_title_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/priority_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:visibility="gone">

            <ImageView
                android:id="@+id/priority_dot_3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/widget_dot"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/priority_title_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="13sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/kanban_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No tasks"
        android:textColor="#9CA3AF"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Setup state -->
    <TextView
        android:id="@+id/kanban_setup"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Open ClawChat to get started"
        android:textColor="#9CA3AF"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a4a" />

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/kanban_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:gravity="center">

        <TextView
            android:id="@+id/btn_open_tasks"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:text="Open Tasks"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
