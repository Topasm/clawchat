<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header: Month + Year -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/calendar_month"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="March 2026"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/calendar_event_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#9CA3AF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a4a" />

    <!-- Upcoming events list -->
    <LinearLayout
        android:id="@+id/calendar_content"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="6dp"
        android:paddingBottom="4dp">

        <!-- Event row 1 -->
        <LinearLayout
            android:id="@+id/event_row_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/event_time_1"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:textColor="#818CF8"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/event_title_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Event row 2 -->
        <LinearLayout
            android:id="@+id/event_row_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/event_time_2"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:textColor="#818CF8"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/event_title_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Event row 3 -->
        <LinearLayout
            android:id="@+id/event_row_3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/event_time_3"
                android:layout_width="48dp"
                android:layout_height="wrap_content"
                android:textColor="#818CF8"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/event_title_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#E5E7EB"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Empty state -->
    <TextView
        android:id="@+id/calendar_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No upcoming events"
        android:textColor="#9CA3AF"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Loading state -->
    <TextView
        android:id="@+id/calendar_loading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Refreshing..."
        android:textColor="#9CA3AF"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Setup state -->
    <TextView
        android:id="@+id/calendar_setup"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="Open ClawChat to get started"
        android:textColor="#9CA3AF"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2a2a4a" />

    <!-- Footer -->
    <LinearLayout
        android:id="@+id/calendar_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:gravity="center">

        <TextView
            android:id="@+id/btn_open_calendar"
            android:layout_width="match_parent"
            android:layout_height="32dp"
            android:background="@drawable/widget_button_bg"
            android:gravity="center"
            android:text="Open Calendar"
            android:textColor="#FFFFFF"
            android:textSize="13sp" />
    </LinearLayout>
</LinearLayout>
