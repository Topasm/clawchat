# Server
HOST=127.0.0.1
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/clawchat.db

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY_HOURS=24
PIN=replace-with-a-strong-random-pin

# AI — delegates to OpenClaw gateway (default) or Claude Code CLI
# AI_PROVIDER: "ollama" (default), "openai", or "claude_code"
# Set AI_PROVIDER=claude_code to use the locally installed Claude Code CLI
AI_PROVIDER=ollama
AI_BASE_URL=http://127.0.0.1:18789
AI_API_KEY=your-openclaw-gateway-token
AI_MODEL=openclaw
